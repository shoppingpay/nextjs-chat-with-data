DATABASE_URL="postgresql://user:password@localhost:5433/nextjs_md_project"
# DATABASE_URL_FILE="/run/secrets/database_url"
REDIS_URL="redis://localhost:6379"
# REDIS_URL_FILE="/run/secrets/redis_url"
NEXTAUTH_URL="http://localhost:3000"
BACKEND_API_URL="http://localhost:4000"
BACKEND_INTERNAL_API_KEY="replace-with-a-long-random-internal-api-key"
# BACKEND_INTERNAL_API_KEY_FILE="/run/secrets/backend_internal_api_key"
BACKEND_PORT="4000"
SEED_SYS_ADMIN_PASSWORD="replace-with-a-strong-seed-password"
# SEED_SYS_ADMIN_PASSWORD_FILE="/run/secrets/seed_sys_admin_password"
TRUST_PROXY_HEADERS="false"

# --- AI Chat (Phase 1-3) ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MAIN_MODEL="qwen2.5:7b"
OLLAMA_GUARDRAIL_MODEL="qwen2.5:0.5b"
OLLAMA_EMBEDDING_MODEL="bge-m3"
OLLAMA_REQUEST_TIMEOUT_MS="30000"

# Qdrant (Phase 3)
QDRANT_URL="http://localhost:6333"
QDRANT_COLLECTION="coffee_knowledge"

# MCP Server (Phase 3) — absolute path to compiled JS, or use tsx for dev
MCP_SERVER_COMMAND="node"
MCP_SERVER_ARGS="packages/mcp-server/dist/index.js"
